{
  "name": "hisab-erp",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/build-i18n-index.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/build-i18n-index.mjs",
    "build": "next build && node scripts/check-public-prerender.mjs",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "i18n:report": "node scripts/build-i18n-index.mjs && node scripts/i18n-audit.mjs",
    "i18n:check": "node scripts/build-i18n-index.mjs && node scripts/i18n-audit.mjs --check",
    "i18n:quality": "node scripts/translation-quality.mjs --check",
    "check": "npm run i18n:check && npm run i18n:quality && npm run typecheck && npm test && npm run build",
    "audit:production": "npm audit --omit=dev --audit-level=moderate",
    "verify:production": "node scripts/production-release-gate.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "0.12.3",
    "@supabase/supabase-js": "2.110.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.3",
    "@vercel/speed-insights": "^2.0.0",
    "next": "16.2.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
