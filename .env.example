# Supabase project settings. The app stays in safe demo mode when these are absent.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional service-role key for trusted server jobs only. Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Public production origin used for auth redirects and canonical URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional monitoring endpoint that accepts JSON error events.
MONITORING_WEBHOOK_URL=

# Optional comma-separated allowlist for Content Security Policy connect-src.
CSP_CONNECT_SRC=
