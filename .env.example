# Supabase project settings. The app stays in safe demo mode when these are absent.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service-role key for trusted server jobs, signed provider callbacks and billing reconciliation only.
# Never expose it to the browser or prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe subscription billing. Create these in Stripe test mode first, then production.
# Prefer a restricted API key (rk_) with only the Checkout, Billing, Customer and Product permissions this app needs.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2026-06-24.dahlia
# Keep a stable label for Stripe Checkout analytics. It must end with eight lowercase letters.
STRIPE_INTEGRATION_IDENTIFIER=hisaberp_checkout_qmzktjfw

# Keep false until Stripe keys, webhook delivery, Apple/Google provider settings and production validation are complete.
# When true, protected workspace access may require an active or trialing subscription.
BILLING_ENFORCEMENT_ENABLED=false

# Provider callback tokens. Generate separate long random values and keep them server-only.
TELEBIRR_CALLBACK_TOKEN=
MPESA_CALLBACK_TOKEN=

# Public production origin used for auth redirects, Stripe return URLs and canonical URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional monitoring endpoint that accepts JSON error events.
MONITORING_WEBHOOK_URL=

# Optional comma-separated allowlist for Content Security Policy connect-src.
CSP_CONNECT_SRC=

# Server/CI backup controls. Never prefix these values with NEXT_PUBLIC_.
DATABASE_URL=
BACKUP_ENCRYPTION_PASSPHRASE=
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=35

# Isolated restore drills require a different disposable database.
RESTORE_DATABASE_URL=
ALLOW_RESTORE_TEST=ISOLATED_TEST_DATABASE
